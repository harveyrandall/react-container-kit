{
  "name": "unstated-next-lib",
  "version": "1.0.0",
  "description": "TypeScript utilities and helpers for unstated-next state management",
  "packageManager": "yarn@4.13.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest typecheck",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "unstated-next": "^1.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "happy-dom": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "unstated-next": "^1.1.0",
    "vitest": "^2.0.0"
  }
}
